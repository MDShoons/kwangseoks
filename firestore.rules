rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.email == "kos20050627@gmail.com" ||
          request.auth.token.email == "shinestone0106@kakao.com"
        );
    }

    // 아이디 중복확인과 아이디 기반 로그인을 위한 컬렉션입니다.
    // read는 로그인 전 아이디 확인을 위해 허용합니다.
    // create는 로그인한 사용자가 자기 uid로만 만들 수 있고, 이미 존재하는 아이디는 만들 수 없습니다.
    match /loginIds/{loginId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.loginId == loginId
        && !exists(/databases/$(database)/documents/loginIds/$(loginId));

      allow update: if false;
      allow delete: if isAdmin();
    }

    // 회원 정보
    match /users/{userId} {
      // 본인은 자기 회원정보를 읽고 쓸 수 있습니다.
      allow read, create, update: if signedIn() && request.auth.uid == userId;

      // 관리자는 회원정보를 읽을 수 있습니다.
      allow read: if isAdmin();

      // 회원 삭제는 일단 막아둡니다. 실제 회원탈퇴 기능 만들 때 별도 설계하세요.
      allow delete: if false;
    }

    // 사이트 템플릿 설정
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 아카이브 콘텐츠
    match /contents/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
