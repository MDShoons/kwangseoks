rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.email == "kos20050627@gmail.com" ||
          request.auth.token.email == "shinestone0106@kakao.com"
        );
    }

    match /loginIds/{loginId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.loginId == loginId
        && !exists(/databases/$(database)/documents/loginIds/$(loginId));

      allow delete: if signedIn() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow update: if false;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
