rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.email == "shinestone0106@kakao.com" ||
          request.auth.token.email == "kos20050627@gmail.com"
        );
    }

    match /loginIds/{loginId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.loginId == loginId
        && request.resource.data.email == request.auth.token.email;

      // 회원 탈퇴 시 본인의 loginId 문서만 삭제할 수 있게 허용합니다.
      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;

      allow update: if false;
    }

    match /users/{userId} {
      // 본인 회원 문서는 본인이 생성/조회/수정할 수 있습니다.
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      // 마이페이지 수정: 이름/전화번호 저장이 막히지 않도록 본인 update 허용.
      // 앱에서는 uid/email/loginId/role을 사용자가 직접 입력하지 못하게 막아두었습니다.
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());

      // 회원 탈퇴 시 본인 문서 삭제 허용.
      allow delete: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /templateSettings/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pageCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if signedIn();
      allow create, update: if signedIn();

      match /messages/{messageId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 3000
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && (
            request.resource.data.role == "user" ||
            request.resource.data.role == "system" ||
            (
              request.resource.data.role == "member" &&
              request.resource.data.generated == true &&
              request.resource.data.source == "cloudflare-workers-ai"
            )
          );

        allow update: if false;

        allow delete: if signedIn() && (
          isAdmin() ||
          resource.data.ownerUid == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          resource.data.source == "cloudflare-workers-ai" ||
          resource.data.role == "system"
        );
      }
    }
  }
}
