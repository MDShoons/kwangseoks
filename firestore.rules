rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.email == "shinestone0106@kakao.com" ||
          request.auth.token.email == "kos20050627@gmail.com"
        );
    }

    match /loginIds/{loginId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.loginId == loginId
        && request.resource.data.email == request.auth.token.email;
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /templateSettings/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pageCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if signedIn();
      allow create, update: if signedIn();

      match /messages/{messageId} {
        allow read: if signedIn();

        // 브라우저에서 직접 만들 수 있는 것은 사용자 발화, 입장 안내,
        // 그리고 Cloudflare Workers AI 응답을 받은 뒤 저장하는 generated member 메시지입니다.
        // 주의: Cloudflare Worker가 Firestore Admin 권한으로 직접 쓰지 않는 간단 구조라서,
        // generated member 저장은 로그인 사용자 uid 기준으로 허용합니다.
        allow create: if signedIn()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && (
            request.resource.data.role == "user" ||
            request.resource.data.role == "system" ||
            (
              request.resource.data.role == "member" &&
              request.resource.data.generated == true &&
              request.resource.data.source == "cloudflare-workers-ai"
            )
          );
        allow update, delete: if false;
      }
    }
  }
}
