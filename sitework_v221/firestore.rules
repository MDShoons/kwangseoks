rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.email == "shinestone0106@kakao.com" ||
          request.auth.token.email == "kos20050627@gmail.com"
        );
    }

    match /loginIds/{loginId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.loginId == loginId
        && request.resource.data.email == request.auth.token.email;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /templateSettings/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pageCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if signedIn();
      allow create, update: if signedIn();

      match /messages/{messageId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 3000
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && (
            request.resource.data.role == "user" ||
            request.resource.data.role == "system" ||
            (
              request.resource.data.role == "member" &&
              request.resource.data.generated == true &&
              request.resource.data.source == "cloudflare-workers-ai"
            )
          );

        allow update: if false;

        // 대화 초기화 버튼이 실제로 현재 방의 로그를 비울 수 있도록 허용합니다.
        // 로그인 사용자가 만든 사용자/시스템/AI 생성 메시지를 삭제할 수 있습니다.
        allow delete: if signedIn() && (
          isAdmin() ||
          resource.data.ownerUid == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          resource.data.source == "cloudflare-workers-ai" ||
          resource.data.role == "system"
        );
      }
    }
  }
}
